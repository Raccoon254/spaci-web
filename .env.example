# Neon Postgres connection string (pooled). Same provider stevetom uses.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Direct (non-pooled) connection, used by prisma migrate / db push.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Optional: where the built installers are actually hosted. The /updates feed
# 302-redirects installer requests here. Leave unset to fall back to the
# GitHub Releases download URL pattern. Do NOT point this back at /updates.
INSTALLER_BASE="https://github.com/Raccoon254/spaci/releases/latest/download"

# Shared secret required to POST /api/releases when publishing a new release.
RELEASE_PUBLISH_SECRET="change-me"
