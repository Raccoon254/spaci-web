    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.2.0",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "prisma": "^5.20.0",
    "svelte": "^4.2.18",
    "svelte-check": "^3.8.0",
    "tslib": "^2.6.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  }
}
