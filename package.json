{
  "name": "spaci-web",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "Spaci marketing site, changelog and update feed. Built by kentom.co.ke.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
