// Prisma schema for the Spaci web backend.
//
// The static src/lib/releases.ts stays the canonical list rendered on the site.
// This database mirrors that data (via prisma/seed.ts and the POST /api/releases
// publish hook) so the dynamic endpoints can serve and analyse it.
//
// IMPORTANT: Spaci shares the kentom.co.ke Neon database with the stevetom
// portfolio, so every model lives in its OWN Postgres schema ("spaci"), NOT in
// "public". This keeps `prisma db push` scoped to the spaci schema and means it
// can never see, alter or drop the portfolio's tables in the public schema.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["spaci"]
}

model Release {
  id        String        @id @default(cuid())
  version   String        @unique
  date      DateTime
  tag       String
  major     Boolean       @default(false)
  summary   String
  added     String[]
  improved  String[]
  fixed     String[]
  createdAt DateTime      @default(now())
  files     ReleaseFile[]

  @@schema("spaci")
}

model ReleaseFile {
  id        String  @id @default(cuid())
  platform  String
  arch      String
  file      String
  size      String
  bytes     Int
  sha512    String  @default("")
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  releaseId String

  @@index([releaseId])
  @@schema("spaci")
}

// Release-announcement signups ("notify me on new releases").
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  confirmed Boolean  @default(false)

  @@schema("spaci")
}

// Simple download analytics, one row per installer download.
model DownloadEvent {
  id       String   @id @default(cuid())
  version  String
  platform String
  file     String
  at       DateTime @default(now())

  @@index([version])
  @@schema("spaci")
}
